rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {  
      return isAuthenticated() && 
             request.auth.token.email.lower() == 'marc.aeschbach@icloud.com';
    }

    function isSecretValid() {
      return (request.resource != null && request.resource.data.adminSecret == 'AIzaSyCILlCLzxyCOGvbc01Z7LPYlPS9tYS0ftM') ||
             (resource != null && resource.data.adminSecret == 'AIzaSyCILlCLzxyCOGvbc01Z7LPYlPS9tYS0ftM');
    }

    // Projects, Downloads, Videos, News: Publicly readable, admin / backend editable
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() || isSecretValid();
    }

    match /downloads/{downloadId} {
      allow read: if true;
      allow write: if isAdmin() || isSecretValid();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin() || isSecretValid();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin() || isSecretValid();
    }

    // Commands: Publicly readable, admin / backend editable
    match /commands/{commandId} {
      allow read: if true;
      allow write: if isAdmin() || isSecretValid();
    }

    // Users collection: owner can read/write their own info, but cannot modify role. Admin has full rights.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Premium collection: owner can read and create, can only update status to 'upgraded'
    match /premium/{subId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'upgraded') || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders collection: owner can read/create, cannot edit or delete. Admin has full rights.
    match /orders/{orderId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Supporters collection: publicly readable, admin writable, or owner writable
    match /supporters/{supporterId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(supporterId);
    }
  }
}
