rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email.lower() == 'marc.aeschbach@icloud.com';
    }

    // Helper function to check if the user is premium
    function isPremium(userId) {
      return firestore.exists(/databases/$(database)/documents/premium/$(userId)) &&
             firestore.get(/databases/$(database)/documents/premium/$(userId)).data.tier >= 2;
    }

    // Projects assets: readable by anyone, only writable by admin
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Images (covers, news, gallery): readable by anyone, only writable by admin
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Free downloads: readable by anyone, only writable by admin
    match /downloads/free/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Premium downloads: readable by premium users/admins, only writable by admin
    match /downloads/premium/{allPaths=**} {
      allow read: if isAdmin() || (request.auth != null && isPremium(request.auth.uid));
      allow write: if isAdmin();
    }

    // User-specific uploads (avatars, attachments, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read: if true; // Publicly viewable avatars
      allow write: if isOwner(userId) || isAdmin();
    }

    // Fallback: Default deny all other paths unless admin
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
